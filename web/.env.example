# ──────────────────────────────────────────────
# Green Carbon HR Tools v2 — 環境変数テンプレート
# .env.local にコピーして実値を埋めてください
# ──────────────────────────────────────────────

# Supabase（https://app.supabase.com で新規プロジェクト作成 → Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # サーバ側のみで使用、絶対公開しない

# Google Workspace SSO
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 クライアントID
# 承認済みリダイレクトURI: https://<your-domain>/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=green-carbon.inc   # ドメイン制限（社外Googleアカウントを弾く）

# Slack 連携（Phase 3）
# OAuth インストールフローを使う場合は CLIENT_ID/SECRET を設定
# シングルテナント運用で固定の Bot トークンを使う場合は SLACK_BOT_TOKEN のみで OK
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=          # 任意：手動で発行した xoxb-... を直接入れる場合
SLACK_SIGNING_SECRET=
SLACK_APP_ID=

# freee 人事労務 API（Phase 3）
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=
FREEE_REDIRECT_URI=https://<your-domain>/api/freee/callback

# Anthropic（Phase 5 — AI Copilot 用）
ANTHROPIC_API_KEY=

# OpenAI（Whisper API 音声入力用）
OPENAI_API_KEY=

# AI レート制限（任意 — 未設定なら下記デフォルト適用）
# AI_LIMIT_PER_USER_MIN=20
# AI_LIMIT_PER_USER_HOUR=100
# AI_LIMIT_PER_USER_DAY=500
# AI_LIMIT_GLOBAL_DAY=5000

# アプリ設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
